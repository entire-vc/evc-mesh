# EVC Mesh — Environment Variables
# Copy to .env and adjust values for your environment.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8005
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# PostgreSQL (port 5437 per local-dev-ports.md)
DB_HOST=localhost
DB_PORT=5437
DB_USER=mesh
DB_PASSWORD=mesh
DB_NAME=mesh
DB_SSL_MODE=disable

# Redis (port 6383 per local-dev-ports.md)
REDIS_HOST=localhost
REDIS_PORT=6383
REDIS_PASSWORD=
REDIS_DB=0

# NATS JetStream
NATS_URL=nats://localhost:4223

# S3 / MinIO (ports 9002/9003 per local-dev-ports.md)
S3_ENDPOINT=localhost:9002
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=mesh-artifacts
S3_REGION=us-east-1
S3_USE_SSL=false
# Optional: public base URL for artifact downloads (leave empty to use presigned S3 URLs)
S3_PUBLIC_URL=

# Auth
JWT_SECRET=change-me-in-production
CASDOOR_ENDPOINT=
CASDOOR_CLIENT_ID=
AGENT_KEY_PREFIX=agk

# CORS (comma-separated origins, use * for development only)
MESH_CORS_ORIGINS=*

# Rate limiting
MESH_RATE_LIMIT_ENABLED=true
MESH_RATE_LIMIT_AUTH_RPM=20
MESH_RATE_LIMIT_API_RPM=600

# Spark agent catalog integration (disabled by default)
MESH_SPARK_URL=https://spark.entire.vc
MESH_SPARK_ENABLED=false
