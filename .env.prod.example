# EVC Mesh — Production Environment Variables
# Copy to .env.prod and fill in all required values before running:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# =============================================================================
# REQUIRED — these have no safe defaults and MUST be changed
# =============================================================================

# PostgreSQL password
POSTGRES_PASSWORD=your-secure-postgres-password

# Redis password
REDIS_PASSWORD=your-secure-redis-password

# JWT signing secret (min 32 characters, random)
JWT_SECRET=your-32-char-random-jwt-secret-here

# MinIO / S3 credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-secure-minio-password

# =============================================================================
# RECOMMENDED — change for your deployment
# =============================================================================

# CORS: comma-separated list of allowed origins (use "*" only for testing)
CORS_ORIGINS=https://your-domain.com

# =============================================================================
# OPTIONAL — ports (defaults shown, change to avoid conflicts)
# =============================================================================

HTTP_PORT=80
API_PORT=8005
MCP_PORT=8081
