COMPOSE_PROJECT_NAME=evc-mesh

# Required — set before first deploy
POSTGRES_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Admin seed (first startup only)
MESH_SEED_ADMIN=true
MESH_ADMIN_EMAIL=admin@localhost
MESH_ADMIN_PASSWORD=
MESH_ADMIN_NAME=Admin

# Optional
API_PORT=8005
HTTP_PORT=80
MCP_PORT=8081
CORS_ORIGINS=https://your-domain.com
GRAFANA_PASSWORD=admin
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
