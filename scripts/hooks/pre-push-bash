#!/bin/bash
# Pre-push hook for Bash repos (evc-mesh-openclaw-skill)
# Blocks direct push to main/master only (no build/test for shell scripts)
#
# Install:
#   ./scripts/install-hooks.sh PATH bash

set -e

remote="$1"

# Block pushes to main/master
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" =~ refs/heads/(main|master)$ ]]; then
        echo "ERROR: Direct push to main/master is blocked."
        echo "Please use a feature branch and create a PR."
        exit 1
    fi
done

echo "Pre-push checks passed."
exit 0
